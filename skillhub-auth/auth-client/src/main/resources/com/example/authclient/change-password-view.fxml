<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.authclient.ChangePasswordController"
      spacing="15"
      alignment="CENTER"
      style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <!-- TITRE -->
    <Label text="Changer mon mot de passe"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Toutes les règles de sécurité s'appliquent"
           style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>

    <Separator/>

    <!-- FORMULAIRE -->
    <VBox spacing="12" alignment="CENTER"
          style="-fx-background-color: white; -fx-padding: 20;
                 -fx-border-color: #ddd; -fx-border-radius: 8;
                 -fx-background-radius: 8;">

        <Label text="Email" style="-fx-font-weight: bold;"/>
        <TextField fx:id="emailField"
                   promptText="alice@mail.com"
                   style="-fx-pref-width: 300px;"/>

        <Label text="Ancien mot de passe" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="oldPasswordField"
                       promptText="AncienMotDePasse123!"
                       style="-fx-pref-width: 300px;"/>

        <Label text="Nouveau mot de passe" style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="newPasswordField"
                       promptText="NouveauMotDePasse123!"
                       style="-fx-pref-width: 300px;"/>

        <Label text="Confirmer le nouveau mot de passe"
               style="-fx-font-weight: bold;"/>
        <PasswordField fx:id="confirmPasswordField"
                       promptText="NouveauMotDePasse123!"
                       style="-fx-pref-width: 300px;"/>

        <Label text="Min. 12 caractères, 1 majuscule, 1 minuscule, 1 chiffre, 1 spécial"
               style="-fx-font-size: 10px; -fx-text-fill: #7f8c8d;"
               wrapText="true"/>

        <Button text="Changer le mot de passe"
                onAction="#handleChangePassword"
                style="-fx-background-color: #e67e22; -fx-text-fill: white;
                       -fx-pref-width: 300px; -fx-pref-height: 35px;
                       -fx-font-size: 13px; -fx-cursor: hand;"/>

        <Label fx:id="messageLabel"
               style="-fx-font-size: 12px;"
               wrapText="true"/>
    </VBox>

    <!-- BOUTON RETOUR -->
    <Button text="Retour à l'accueil"
            onAction="#handleBack"
            style="-fx-background-color: #95a5a6; -fx-text-fill: white;
                   -fx-pref-width: 300px; -fx-pref-height: 35px;
                   -fx-font-size: 13px; -fx-cursor: hand;"/>

</VBox>