<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.authclient.AuthController"
      spacing="15"
      alignment="CENTER"
      style="-fx-background-color: #f5f5f5;">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <!-- TITRE -->
    <Label text="TP4 — Authentification HMAC"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Protocole sécurisé — le mot de passe ne circule jamais"
           style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;"/>

    <Separator/>

    <!-- ONGLETS INSCRIPTION / LOGIN -->
    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE"
             style="-fx-background-color: white;">

        <!-- ONGLET INSCRIPTION -->
        <Tab text="Inscription">
            <VBox spacing="12" alignment="CENTER">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Email" style="-fx-font-weight: bold;"/>
                <TextField fx:id="registerEmail"
                           promptText="alice@mail.com"
                           style="-fx-pref-width: 300px;"/>

                <Label text="Mot de passe (min. 12 caractères)"
                       style="-fx-font-weight: bold;"/>
                <PasswordField fx:id="registerPassword"
                               promptText="MonMotDePasse123!"
                               style="-fx-pref-width: 300px;"/>

                <Button text="S'inscrire"
                        fx:id="registerButton"
                        onAction="#handleRegister"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;
                               -fx-pref-width: 300px; -fx-pref-height: 35px;
                               -fx-font-size: 13px; -fx-cursor: hand;"/>

                <Label fx:id="registerMessage"
                       style="-fx-font-size: 12px;"
                       wrapText="true"/>
            </VBox>
        </Tab>

        <!-- ONGLET LOGIN -->
        <Tab text="Connexion">
            <VBox spacing="12" alignment="CENTER">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Email" style="-fx-font-weight: bold;"/>
                <TextField fx:id="loginEmail"
                           promptText="alice@mail.com"
                           style="-fx-pref-width: 300px;"/>

                <Label text="Mot de passe" style="-fx-font-weight: bold;"/>
                <PasswordField fx:id="loginPassword"
                               promptText="MonMotDePasse123!"
                               style="-fx-pref-width: 300px;"/>

                <Label text="Le mot de passe sert à calculer le HMAC — jamais envoyé au serveur"
                       style="-fx-font-size: 10px; -fx-text-fill: #27ae60;"
                       wrapText="true"/>

                <Button text="Se connecter"
                        fx:id="loginButton"
                        onAction="#handleLogin"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;
                               -fx-pref-width: 300px; -fx-pref-height: 35px;
                               -fx-font-size: 13px; -fx-cursor: hand;"/>

                <Label fx:id="loginMessage"
                       style="-fx-font-size: 12px;"
                       wrapText="true"/>
            </VBox>
        </Tab>
    </TabPane>
</VBox>